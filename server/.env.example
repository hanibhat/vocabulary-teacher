CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,null
CACHE_CRON_SCHEDULE=0 * * * *
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
TELEGRAM_WEBHOOK_SECRET_TOKEN=your-telegram-webhook-secret-token
# Optional: chat ID to receive startup confirmation
TELEGRAM_ADMIN_CHAT_ID=
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id
GOOGLE_SPREADSHEET_RANGE=A:F
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_VOCABULARY=Wortschatz
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openrouter/free
# Optional: leave empty to read every sheet tab in the spreadsheet.
GOOGLE_SHEET_NAMES=
